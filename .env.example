# Shopify (from Partner Dashboard or `shopify app env show`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,write_metaobjects,write_metaobject_definitions

# Production app URL — Railway public domain, no trailing slash
# Example: https://ai-catalog-optimizer-production.up.railway.app
SHOPIFY_APP_URL=

# Local dev: use Railway Postgres "DATABASE_PUBLIC_URL" (not the internal .railway.internal URL)
# Append ?sslmode=require if connection fails
DATABASE_URL=postgresql://postgres:password@host:port/railway?sslmode=require

# OpenRouter
OPENROUTER_API_KEY=

# Billing — set false in production for real charges
SHOPIFY_BILLING_TEST=true

# Optional
# FREE_MONTHLY_LIMIT=10
# LLM_MODEL=deepseek/deepseek-v4-flash
